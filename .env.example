# Copy to .env.local and fill in. Same Supabase project as greyform.org —
# reuse SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY from that repo's .env.local.

# Supabase — server-only. The service-role key bypasses RLS and must never be
# exposed to the client. Imported solely via src/lib/supabase.ts ("server-only").
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Single-user auth (src/lib/auth.ts). Pick a long passphrase, distinct from
# the greyform.org admin password.
STUDIO_PASSWORD=

# Resend — reminder emails and .ics invites to yourself. Same key as the site.
RESEND_API_KEY=

# Web Push (generate once: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron endpoints refuse requests without this shared secret.
CRON_SECRET=

# Optional overrides (sensible defaults in code): absolute base URL used in
# push payloads, the From address for studio email, and where reminder email
# lands.
# STUDIO_URL=https://studio.greyform.org
# STUDIO_FROM_EMAIL="Greyform Studio <studio@greyform.org>"
# STUDIO_OWNER_EMAIL=you@example.com
